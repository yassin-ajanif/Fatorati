<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.FactureFournisseur.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.FactureFournisseur.Views.FactureFournisseurListView"
             x:Name="FactureFournisseurListRoot"
             x:DataType="vm:FactureFournisseurListViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewFactureFournisseurCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <ComboBox Width="220" PlaceholderText="{Binding WmFilterPayee}" SelectedIndex="{Binding PayeeFilterIndex}">
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureFournisseurListRoot.((vm:FactureFournisseurListViewModel)DataContext).LblPayeeFilterAll}"/>
        </ComboBoxItem>
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureFournisseurListRoot.((vm:FactureFournisseurListViewModel)DataContext).LblPayeeFilterUnpaid}"/>
        </ComboBoxItem>
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureFournisseurListRoot.((vm:FactureFournisseurListViewModel)DataContext).LblPayeeFilterPaid}"/>
        </ComboBoxItem>
      </ComboBox>
      <TextBox MinWidth="260" MaxWidth="420" VerticalAlignment="Center"
               Watermark="{Binding SearchWatermark}" Text="{Binding SearchText}"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
      <Border Grid.Row="0" Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8" Margin="0,0,0,1">
        <Grid ColumnDefinitions="*,*,100,100,118,100,*">
          <TextBlock Grid.Column="0" Text="{Binding ColHeaderRef}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" Text="{Binding ColHeaderParty}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="{Binding ColHeaderDate}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHeaderEcheance}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="{Binding ColHeaderPayee}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="5" Text="{Binding ColHeaderTtc}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="6" Text="{Binding ColHeaderNote}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:FactureFournisseurListRow">
            <Border Padding="10,8" Background="Transparent">
              <Border.ContextMenu>
                <ContextMenu Opening="OnRowContextMenuOpening">
                  <MenuItem Header="{Binding #FactureFournisseurListRoot.((vm:FactureFournisseurListViewModel)DataContext).MenuDeleteFactureFournisseur}"
                            Command="{Binding #FactureFournisseurListRoot.((vm:FactureFournisseurListViewModel)DataContext).DeleteFactureFournisseurCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="*,*,100,100,118,100,*">
                <TextBlock Grid.Column="0" Text="{Binding FactureFournisseur.Numero}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding FournisseurNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding DateShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding EcheanceShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" Text="{Binding StatutLabel}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="5" Text="{Binding TtcLabel}" VerticalAlignment="Center" FontWeight="SemiBold" TextAlignment="End" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="6" Text="{Binding NotePreview}" VerticalAlignment="Center" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <Border Grid.Row="2" Padding="8,6" Margin="0,6,0,0"
            Background="{DynamicResource CourseraSurfaceBrush}"
            BorderBrush="{DynamicResource CourseraBorderBrush}" BorderThickness="1" CornerRadius="8">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
        <Button Content="⏮ First" Command="{Binding Pagination.FirstPageCommand}"
                IsEnabled="{Binding Pagination.HasPrevious}" FontSize="13"/>
        <Button Content="‹ Prev" Command="{Binding Pagination.PreviousPageCommand}"
                IsEnabled="{Binding Pagination.HasPrevious}" FontSize="13"/>
        <TextBlock Text="{Binding Pagination.CurrentPage}" VerticalAlignment="Center" FontSize="13"/>
        <TextBlock Text="/" VerticalAlignment="Center" FontSize="13"/>
        <TextBlock Text="{Binding Pagination.TotalPages}" VerticalAlignment="Center" FontSize="13"/>
        <TextBlock Text="{Binding Pagination.TotalCount, StringFormat='({0} total)'}" VerticalAlignment="Center"
                   FontSize="12" Opacity="0.6"/>
        <Button Content="Next ›" Command="{Binding Pagination.NextPageCommand}"
                IsEnabled="{Binding Pagination.HasNext}" FontSize="13"/>
        <Button Content="Last ⏭" Command="{Binding Pagination.LastPageCommand}"
                IsEnabled="{Binding Pagination.HasNext}" FontSize="13"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
