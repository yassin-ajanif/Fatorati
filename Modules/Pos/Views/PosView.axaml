<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Pos.ViewModels"
             xmlns:models="using:GestionCommerciale.Modules.Stock.Models"
             x:Class="GestionCommerciale.Modules.Pos.Views.PosView"
             x:DataType="vm:PosViewModel"
             x:Name="ThisControl">
  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
    <!-- Search -->
    <TextBox Grid.Row="0" Watermark="{Binding SearchWatermark}" Text="{Binding SearchText}"
             TextChanged="OnSearchTextChanged" KeyDown="OnSearchKeyDown" Margin="0,0,0,12"/>

    <!-- Product quick list -->
    <ListBox Grid.Row="1" ItemsSource="{Binding SearchResults}" MaxHeight="180"
             SelectedItem="{Binding SelectedProduct}" Margin="0,0,0,12"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:ProductSearchRow">
          <Border Padding="8 6" CornerRadius="6" BorderThickness="1"
                  Background="{DynamicResource CourseraSurfaceBrush}">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Reference}" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock Text="{Binding Designation}" Classes="subtle" FontSize="12"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding PrixVenteTtc, StringFormat='{}{0:N2} DH TTC'}"
                         VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
              <Button Grid.Column="2" Content="+" VerticalAlignment="Center" Classes="primary"
                      Command="{Binding $parent[UserControl].((vm:PosViewModel)DataContext).AddProductCommand}"
                      CommandParameter="{Binding .}"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Cart -->
    <Border Grid.Row="2" CornerRadius="8" BorderThickness="1" Margin="0,0,0,12"
            Background="{DynamicResource CourseraSurfaceBrush}">
      <Grid RowDefinitions="Auto,*" Margin="8">
        <TextBlock Grid.Row="0" Text="{Binding CartTitle}" FontWeight="SemiBold" FontSize="15" Margin="0 0 0 6"/>
        <ScrollViewer Grid.Row="1">
          <ItemsControl ItemsSource="{Binding Cart}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CartLineRow">
                <Border Padding="6 4" Margin="0 0 0 4" CornerRadius="6" BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                      <TextBlock Text="{Binding Designation}" FontWeight="SemiBold" FontSize="13"/>
                      <TextBlock Text="{Binding Reference}" Classes="subtle" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                      <TextBlock Text="{Binding PrixUnitaireTtc, StringFormat='{}{0:N2} DH'}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="4" Margin="0,0,8,0">
                      <Button Content="&#x2212;" Width="32" Height="32" FontSize="20" FontWeight="Bold" Classes="primary" Padding="0"
                              Command="{Binding $parent[UserControl].((vm:PosViewModel)DataContext).DecreaseQtyCommand}"
                              CommandParameter="{Binding .}"/>
                      <TextBlock Text="{Binding Quantite}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                 FontWeight="SemiBold" Width="36" TextAlignment="Center" FontSize="15"/>
                      <Button Content="+" Width="32" Height="32" FontSize="20" FontWeight="Bold" Classes="primary" Padding="0"
                              Command="{Binding $parent[UserControl].((vm:PosViewModel)DataContext).IncreaseQtyCommand}"
                              CommandParameter="{Binding .}"/>
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding MontantTtc, StringFormat='{}{0:N2} DH'}"
                               VerticalAlignment="Center" FontWeight="Bold" FontSize="14"
                               HorizontalAlignment="Right" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" MinWidth="32" Height="32" FontSize="16" Padding="6,0"
                            Content="&#x1F5D1;"
                            Command="{Binding $parent[UserControl].((vm:PosViewModel)DataContext).RemoveProductCommand}"
                            CommandParameter="{Binding .}"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- Footer: total + actions -->
    <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
            Background="{DynamicResource CourseraSurfaceBrush}" Padding="14">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <StackPanel Grid.Column="0">
          <TextBlock Text="{Binding TotalLabel}" FontSize="13" Classes="subtle"/>
          <TextBlock Text="{Binding TotalTtc, StringFormat='{}{0:N2} DH'}" FontWeight="Bold" FontSize="22"/>
        </StackPanel>
        <Button Grid.Column="1" Content="{Binding BtnClearCart}" Command="{Binding ClearCartCommand}"
                MinWidth="100" Margin="0,0,12,0"/>
        <Button Grid.Column="2" Content="{Binding BtnCheckout}" Command="{Binding CheckoutCommand}"
                MinWidth="100" Classes="primary" IsEnabled="{Binding HasItems}"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
