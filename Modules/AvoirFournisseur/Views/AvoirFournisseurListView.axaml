<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.AvoirFournisseur.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.AvoirFournisseur.Views.AvoirFournisseurListView"
             x:DataType="vm:AvoirFournisseurListViewModel">
  <Grid RowDefinitions="Auto,*" Margin="0,0,0,8">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Button Content="{Binding BtnRefresh}" Command="{Binding LoadCommand}"/>
      <Button Content="{Binding BtnNew}" Command="{Binding NewCommand}"/>
      <Button Content="{Binding BtnPdf}" Command="{Binding ExportPdfCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <TextBox MinWidth="180" Watermark="{Binding SearchText, TargetNullValue='Rechercher…'}"
               Text="{Binding SearchText}" Margin="12,0,0,0"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Padding="8,6" Background="{DynamicResource CourseraSurfaceMutedBrush}"
              CornerRadius="8,8,0,0" BorderThickness="1,1,1,0"
              BorderBrush="{DynamicResource CourseraBorderBrush}">
        <Grid ColumnDefinitions="80,2*,1.2*,1*,1*,2*">
          <TextBlock Grid.Column="0" Text="{Binding ColNumero}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="{Binding ColFournisseur}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="{Binding ColDate}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHt}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
          <TextBlock Grid.Column="4" Text="{Binding ColTtc}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
          <TextBlock Grid.Column="5" Text="{Binding ColMotif}" FontWeight="SemiBold" Margin="8,0,0,0"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected}"
               BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CourseraBorderBrush}"
               CornerRadius="0,0,8,8" Background="{DynamicResource CourseraSurfaceBrush}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:AvoirFournisseurListRow">
            <Border Padding="8,6" BorderBrush="#18000000" BorderThickness="0,0,0,1">
              <Border.ContextMenu>
                <ContextMenu Opening="OnRowContextMenuOpening">
                  <MenuItem Header="Supprimer" Command="{Binding $parent[UserControl].((vm:AvoirFournisseurListViewModel)DataContext).DeleteCommand}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="80,2*,1.2*,1*,1*,2*">
                <TextBlock Grid.Column="0" Text="{Binding Doc.Numero}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding FournisseurNom}"/>
                <TextBlock Grid.Column="2" Text="{Binding DateShort}"/>
                <TextBlock Grid.Column="3" Text="{Binding HtLabel}" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="{Binding TtcLabel}" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="5" Text="{Binding NotePreview}" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </Grid>
</UserControl>
