<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Auth.ViewModels"
             x:Class="GestionCommerciale.Modules.Auth.Views.HomeView"
             x:DataType="vm:HomeViewModel">
  <Grid>
    <ContentControl Content="{Binding Dashboard}"
                    IsVisible="{Binding ShowDashboard}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
    <StackPanel IsVisible="{Binding ShowWelcomeOnly}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="12"
                MaxWidth="480">
      <TextBlock Text="{Binding Welcome}" TextWrapping="Wrap" FontSize="16"/>
    </StackPanel>
  </Grid>
</UserControl>
