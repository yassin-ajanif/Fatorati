<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Commande.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Commande.Models"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Commande.Views.BCListView"
             x:DataType="vm:BCListViewModel">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnRefresh}" Command="{Binding LoadCommand}"/>
      <Button Content="{Binding BtnNew}" Command="{Binding NewBcCommand}"/>
      <Button Content="{Binding BtnPdf}" Command="{Binding ExportPdfCommand}"/>
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,8,0,0"
             beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="m:BonCommande">
          <TextBlock Text="{Binding Numero}"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
