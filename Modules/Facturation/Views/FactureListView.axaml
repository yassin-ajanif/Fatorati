<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Facturation.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Facturation.Models"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             x:Class="GestionCommerciale.Modules.Facturation.Views.FactureListView"
             x:DataType="vm:FactureListViewModel">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnRefresh}" Command="{Binding LoadCommand}"/>
      <Button Content="{Binding BtnNew}" Command="{Binding NewFactureCommand}"/>
      <Button Content="{Binding BtnExportCsv}" Command="{Binding ExportCsvCommand}"/>
      <Button Content="{Binding BtnPdf}" Command="{Binding ExportPdfCommand}"/>
      <ComboBox ItemsSource="{Binding Statuts}" SelectedItem="{Binding FilterStatut}" Width="200" PlaceholderText="{Binding WmFilterStatut}">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding ., Converter={x:Static conv:StatutFactureLabelConverter.Instance}}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,8,0,0"
             beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="m:Facture">
          <TextBlock Text="{Binding Numero}"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
